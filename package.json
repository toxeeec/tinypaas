{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/tsgo": "0.18.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7.0.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "0.4.4",
      "onFail": "error"
    }
  },
  "allowBuilds": {
    "msgpackr-extract": true
  }
}
