{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@effect/platform-node": "4.0.0-beta.98",
      "@effect/vitest": "4.0.0-beta.98",
      "@vitest/runner": "4.1.10",
      "effect": "4.0.0-beta.98",
      "vitest": "4.1.10"
    }
  },
  "type": "module",
  "scripts": {
    "check": "status=0; oxfmt || status=1; oxlint --fix --disable-nested-config || status=1; nub run --recursive --no-bail typecheck || status=1; nub run --recursive --no-bail test || status=1; exit $status",
    "prepare": "effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/tsgo": "0.22.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7.0.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "0.4.4",
      "onFail": "error"
    }
  },
  "allowBuilds": {
    "msgpackr-extract": true
  }
}
